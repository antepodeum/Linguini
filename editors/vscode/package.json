{
  "name": "linguini-vscode",
  "displayName": "Linguini",
  "description": "VS Code language support for Linguini schema and locale files.",
  "version": "0.1.0",
  "publisher": "linguini",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:linguini-schema",
    "onLanguage:linguini-locale"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "open:dev": "npm run compile && code --extensionDevelopmentPath=. ./sample-workspace",
    "audit:prod": "npm audit --omit=dev",
    "vscode:prepublish": "npm run compile",
    "check": "npm run compile && npm audit --audit-level=moderate",
    "dev:host": "npm run compile && node ./scripts/open-extension-host.js"
  },
  "contributes": {
    "languages": [
      {
        "id": "linguini-schema",
        "aliases": [
          "Linguini Schema",
          "linguini-schema"
        ],
        "extensions": [
          ".lgs"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "linguini-locale",
        "aliases": [
          "Linguini Locale",
          "linguini-locale"
        ],
        "extensions": [
          ".lgl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "linguini-schema",
        "scopeName": "source.linguini.schema",
        "path": "./syntaxes/linguini-schema.tmLanguage.json"
      },
      {
        "language": "linguini-locale",
        "scopeName": "source.linguini.locale",
        "path": "./syntaxes/linguini-locale.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Linguini",
      "properties": {
        "linguini.server.path": {
          "type": "string",
          "default": "linguini",
          "description": "Path to the Linguini binary. Used for both `linguini lsp` and formatting unless `linguini.formatting.path` is set."
        },
        "linguini.server.args": {
          "type": "array",
          "default": [
            "lsp"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the Linguini language server binary. Supports `${workspaceFolder}`."
        },
        "linguini.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Linguini language server."
        },
        "linguini.formatter.path": {
          "type": "string",
          "default": "linguini",
          "description": "Path to the Linguini formatter binary. Defaults to resolving `linguini` from PATH. Supports `${workspaceFolder}`."
        },
        "linguini.formatter.args": {
          "type": "array",
          "default": [
            "formatting"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the Linguini formatter binary. The document text is passed on stdin; stdout must contain the formatted document. Supports `${file}`, `${workspaceFolder}`, and `${languageId}` placeholders."
        },
        "linguini.formatter.timeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Maximum time in milliseconds to wait for `linguini formatting` before cancelling formatting."
        },
        "linguini.formatting.path": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Linguini formatter binary. Leave empty to reuse `linguini.server.path`."
        },
        "linguini.formatting.args": {
          "type": "array",
          "default": [
            "formatting"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the Linguini formatter. Defaults to running `linguini formatting` and sending the document through stdin. Supports `${workspaceFolder}` and `${file}` substitutions."
        },
        "linguini.formatting.timeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Maximum time in milliseconds to wait for `linguini formatting` before cancelling formatting."
        },
        "linguini.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic highlighting from `linguini lsp`. Disabled by default because the TextMate grammar provides stable syntax highlighting."
        }
      }
    },
    "configurationDefaults": {
      "[linguini-schema]": {
        "editor.defaultFormatter": "linguini.linguini-vscode",
        "editor.semanticHighlighting.enabled": true
      },
      "[linguini-locale]": {
        "editor.defaultFormatter": "linguini.linguini-vscode",
        "editor.semanticHighlighting.enabled": true
      }
    },
    "semanticTokenScopes": [
      {
        "language": "linguini-schema",
        "scopes": {
          "enum": [
            "entity.name.type.enum.linguini"
          ],
          "enumMember": [
            "variable.other.enummember.linguini"
          ],
          "type": [
            "entity.name.type.linguini"
          ],
          "function": [
            "entity.name.function.linguini"
          ],
          "parameter": [
            "variable.parameter.linguini"
          ],
          "property": [
            "variable.other.member.linguini"
          ],
          "keyword": [
            "keyword.control.linguini"
          ]
        }
      },
      {
        "language": "linguini-locale",
        "scopes": {
          "enum": [
            "entity.name.type.enum.linguini"
          ],
          "enumMember": [
            "variable.other.enummember.linguini"
          ],
          "type": [
            "entity.name.type.linguini"
          ],
          "function": [
            "entity.name.function.linguini"
          ],
          "parameter": [
            "variable.parameter.linguini"
          ],
          "property": [
            "variable.other.member.linguini"
          ],
          "keyword": [
            "keyword.control.linguini"
          ],
          "string": [
            "string.unquoted.linguini"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "linguini.restartServer",
        "title": "Linguini: Restart Language Server"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
