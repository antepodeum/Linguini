enum Fruit {
  apple
  pear
  orange
}

enum Size {
  small
  big
}

type Money = Decimal @currency(code = "USD")
type ShortDate = Date @date(style = "short")

/// Product delivery sentence shown after checkout.
delivery(fruit: Fruit, size: Size, count: Number)

/// Shown near the cart icon.
counted(count: Number, fruit: Fruit)

/// Price and date preview.
price(amount: Money, date: ShortDate)

email_input {
  label
  placeholder
  aria
}
