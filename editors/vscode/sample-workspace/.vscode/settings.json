{
  "linguini.server.path": "cargo",
  "linguini.server.args": [
    "run",
    "--manifest-path",
    "${workspaceFolder}/../../../Cargo.toml",
    "-p",
    "linguini-cli",
    "--",
    "lsp"
  ],
  "linguini.formatting.args": ["formatting"],
  "linguini.semanticHighlighting.enabled": true,
  "[linguini-schema]": {
    "editor.defaultFormatter": "antepod.linguini-vscode",
    "editor.semanticHighlighting.enabled": true
  },
  "[linguini-locale]": {
    "editor.defaultFormatter": "antepod.linguini-vscode",
    "editor.semanticHighlighting.enabled": true
  }
}
