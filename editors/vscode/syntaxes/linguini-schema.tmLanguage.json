{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Linguini Schema",
  "scopeName": "source.linguini.schema",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.linguini.schema",
          "begin": "^\\s*(///)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.comment.linguini.schema"
            }
          },
          "end": "$"
        },
        {
          "name": "comment.line.double-slash.linguini.schema",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.linguini.schema"
            }
          },
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.linguini.schema",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.linguini.schema"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.linguini.schema"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.linguini.schema",
              "match": "\\\\(?:[\"\\\\nrt]|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.enum.linguini.schema",
          "match": "\\b(enum)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.enum.linguini.schema"
            },
            "2": {
              "name": "entity.name.type.enum.linguini.schema"
            }
          }
        },
        {
          "name": "meta.type-alias.linguini.schema",
          "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.linguini.schema"
            },
            "2": {
              "name": "entity.name.type.linguini.schema"
            }
          }
        },
        {
          "name": "meta.message.linguini.schema",
          "match": "^\\s*([a-z_][A-Za-z0-9_]*)\\s*(?=\\(|\\{)",
          "captures": {
            "1": {
              "name": "entity.name.function.message.linguini.schema"
            }
          }
        },
        {
          "name": "meta.parameter.linguini.schema",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.parameter.linguini.schema"
            },
            "2": {
              "name": "punctuation.separator.key-value.linguini.schema"
            },
            "3": {
              "name": "support.type.linguini.schema"
            }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.formatter.attribute.linguini.schema",
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.annotation.linguini.schema"
            },
            "2": {
              "name": "entity.other.attribute-name.linguini.schema"
            }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.type.primitive.linguini.schema",
          "match": "\\b(?:String|Number|Decimal|Date|Plural|Gender)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "constant.language.placeholder.linguini.schema",
          "match": "\\b_\\b"
        },
        {
          "name": "variable.other.member.linguini.schema",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.reference.linguini.schema",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.linguini.schema",
          "match": "="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.linguini.schema",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parameters.linguini.schema",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.comma.linguini.schema",
          "match": ","
        }
      ]
    }
  }
}
