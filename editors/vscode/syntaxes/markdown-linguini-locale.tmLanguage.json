{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Linguini Locale Markdown Code Block",
  "scopeName": "markdown.linguini.locale.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "name": "markup.fenced_code.block.markdown.linguini.locale",
      "begin": "(^|\\G)(\\s{0,3})(`{3,}|~{3,})\\s*(?i:(lgl|linguini-locale))\\s*$",
      "beginCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        },
        "4": {
          "name": "fenced_code.block.language.markdown"
        }
      },
      "end": "(^|\\G)(\\2)(\\3)\\s*$",
      "endCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        }
      },
      "patterns": [
        {
          "include": "source.linguini.locale"
        }
      ]
    }
  ]
}
