{
  "name": "@antepod/linguini-sveltekit",
  "version": "0.1.0-alpha.0",
  "description": "SvelteKit adapter for Linguini web i18n",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./client": {
      "svelte": "./src/client.svelte.js",
      "types": "./src/client.svelte.d.ts",
      "default": "./src/client.svelte.js"
    },
    "./server": {
      "types": "./src/server.d.ts",
      "default": "./src/server.js"
    }
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@antepod/linguini-web": "^0.1.0-alpha.0"
  },
  "scripts": {
    "test": "node --import ./test/register-loader.mjs --test test/*.test.mjs"
  }
}
