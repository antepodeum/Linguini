enum Gender { male, female, neuter, other }

let cart_label = В корзине

impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => яблоко
      few => яблока
      _ => яблок
    }

    form gen(Plural) {
      one => яблока
      _ => яблок
    }

    display {
      short = ябл.
      long = спелое яблоко
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => груша
      few => груши
      _ => груш
    }

    form gen(Plural) {
      one => груши
      _ => груш
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => апельсин
      few => апельсина
      _ => апельсинов
    }

    form gen(Plural) {
      one => апельсина
      _ => апельсинов
    }
  }
}

form Delivered(Plural, Gender) {
  one {
    male => Доставлен
    female => Доставлена
    neuter => Доставлено
    _ => Доставлено
  }
  _ => Доставлены
}

form SizeAdj(Size, Plural, Gender) {
  small {
    one {
      male => маленький
      female => маленькая
      neuter => маленькое
      _ => маленький
    }
    _ => маленьких
  }
  big {
    one {
      male => большой
      female => большая
      neuter => большое
      _ => большой
    }
    _ => больших
  }
  _ => обычные
}

fn DeliveryNote(item: String, Plural, Gender) {
  one {
    female => Доставлена {item}
    _ => Доставлен {item}
  }
  _ => Доставлены {item}
}

/// Product delivery sentence.
delivery = {Delivered(count, fruit.Gender)} {SizeAdj(size, count, fruit.Gender)} {fruit.nom(count)}

counted = {cart_label} {count} {fruit.nom(count)}

price = Цена {amount @currency(code = "RUB")} на {date @date(style = "short")}

email_input {
  label = Email
  placeholder = name@example.com
  aria = Адрес электронной почты
}
