playground_sentence = {Delivered(count, fruit.Gender)} {count} {SizeAdj(size, count, fruit.Gender)} {fruit.nom(count)} pour {GenderPronoun(gender)}. Total {amount @currency(code = "EUR")}; date {date}.
cart_summary = Le panier contient {count} {fruit.nom(count)}
number_format = Format nombre: {value}
currency_format = Format devise: {amount @currency(code = "EUR")}
date_format = Format date: {date}
override_format = Locale override: {amount @number} / {date @date(style = "long")}
