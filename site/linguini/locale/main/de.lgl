nav_web = Web
locale_label = Sprache
hero_eyebrow = Typisierte Lokalisierung für Produktteams
hero_title = Linguini
hero_tagline = Internationalisierung für uns alle
hero_copy = Eine kompilierte Lokalisierungssprache, in der Schemas, Grammatik, CLDR-Formatierung, SvelteKit-Hooks, Cookies und lokalisierte Routen aus einer Quelle entstehen.
hero_term = /lɪŋˈɡwiːni/
hero_term_kind = NOMEN
hero_term_hint = lange, schmale Pastabänder
hero_intro = Linguini macht aus typisierten Lokalisierungsdateien Code, den jede App nutzen kann. Messages, Grammatik, Formatter, Locale-Fallbacks und Web-Routing werden beim Build geprüft.
hero_trait_typed = Typisiert
hero_trait_compiled = Kompiliert
hero_trait_native = Nativ
primary_cta = Docs lesen
secondary_cta = GitHub ansehen
codegen_kicker = Codegenerierung
codegen_title = Ein Schema, typisierte Ausgabe für jeden Runtime
codegen_intro = Linguini analysiert .lgs-Verträge und .lgl-Locale-Logik einmal und erzeugt dann zielspezifische Module mit CLDR-Formatierern, Plural-Selektoren und Framework-Adaptern zur Build-Zeit.
codegen_ts_title = TypeScript / ESM
codegen_ts_desc = Typisierte Message-Funktionen, gemeinsamer Runtime, Deklarationsdateien und optionales Tree-Shaking pro Locale.
codegen_svelte_title = Svelte 5 + SvelteKit
codegen_svelte_desc = Generierter l-Rune, Locale-Wechsel, localizeHref-Helfer und handle / reroute / load-Exports.
codegen_planned_title = Geplante Targets
codegen_planned_intro = Die Roadmap ist bewusst breit: Linguini soll alle praktischen Runtimes, Sprachen und Web-Frameworks erreichen.
codegen_rust = Rust
codegen_kotlin = Kotlin
codegen_swift = Swift
codegen_go = Go
codegen_python = Python
codegen_csharp = C#
codegen_status_shipped = Verfügbar
codegen_status_planned = Geplant
web_kicker = SvelteKit
web_title = Lokalisierter SvelteKit ohne handgeschriebene i18n-Verdrahtung
web_intro = Write normal SvelteKit routes and generated message calls. Linguini keeps the active locale, updates messages reactively, and turns invalid message arguments into TypeScript errors.
web_routing = Use ordinary internal links; the generated reroute hook handles localized URLs.
web_cookie = Locale changes persist through cookies and browser storage without app-level state.
web_fallback = Daten der Basis-Locale werden beim Build in generierte Locale-Module eingebettet.
web_reactivity = The l rune updates UI text immediately after setLocale.
web_links = Einzelne Links können ihre ursprüngliche URL behalten, wenn keine Lokalisierung gewünscht ist.
