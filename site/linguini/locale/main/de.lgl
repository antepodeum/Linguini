playground_sentence = {Delivered(count, fruit.Gender)} {count} {SizeAdj(size, count, fruit.Gender)} {fruit.nom(count)} für {GenderPronoun(gender)}. Summe {amount @currency(code = "EUR")}; Datum {date}.
cart_summary = Warenkorb enthält {count} {fruit.nom(count)}
number_format = Zahlenformat: {value}
currency_format = Währungsformat: {amount @currency(code = "EUR")}
date_format = Datumsformat: {date}
override_format = Locale override: {amount @number} / {date @date(style = "long")}
