impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => Apfel
      _ => Äpfel
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => Birne
      _ => Birnen
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => Orange
      _ => Orangen
    }
  }
}

form SizeAdj(Size, Plural, Gender) {
  small {
    one {
      male => kleiner
      female => kleine
      neuter => kleines
      _ => kleiner
    }
    _ => kleine
  }
  big {
    one {
      male => großer
      female => große
      neuter => großes
      _ => großer
    }
    _ => große
  }
  _ => normale
}

form SizeWord(Size) {
  small => klein
  big => groß
}

form GenderPronoun(Gender) {
  male => ihn
  female => sie
  neuter => es
  _ => es
}

form GenderWord(Gender) {
  male => maskulin
  female => feminin
  neuter => neutrum
  _ => neutral
}

form Delivered(Plural, Gender) {
  one => Geliefert
  _ => Geliefert
}

