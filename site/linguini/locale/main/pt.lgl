impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => maçã
      _ => maçãs
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => pera
      _ => peras
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => laranja
      _ => laranjas
    }
  }
}

form SizeAdj(Size, Plural, Gender) {
  small {
    one {
      male => pequeno
      female => pequena
      neuter => pequeno
      _ => pequeno
    }
    _ {
      male => pequenos
      female => pequenas
      neuter => pequenos
      _ => pequenos
    }
  }
  big {
    one {
      male => grande
      female => grande
      neuter => grande
      _ => grande
    }
    _ {
      male => grandes
      female => grandes
      neuter => grandes
      _ => grandes
    }
  }
  _ => normais
}

form SizeWord(Size) {
  small => pequeno
  big => grande
}

form GenderPronoun(Gender) {
  male => ele
  female => ela
  neuter => ele
  _ => ele
}

form GenderWord(Gender) {
  male => masculino
  female => feminino
  neuter => neutro
  _ => neutro
}

form Delivered(Plural, Gender) {
  one => Entregue
  _ => Entregues
}

