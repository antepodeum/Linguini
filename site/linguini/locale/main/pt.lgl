impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => maçã
      _ => maçãs
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => pera
      _ => peras
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => laranja
      _ => laranjas
    }
  }
}

form SizeAdj(Size, Plural, Gender) {
  small {
    one {
      male => pequeno
      female => pequena
      neuter => pequeno
      _ => pequeno
    }
    _ {
      male => pequenos
      female => pequenas
      neuter => pequenos
      _ => pequenos
    }
  }
  big {
    one {
      male => grande
      female => grande
      neuter => grande
      _ => grande
    }
    _ {
      male => grandes
      female => grandes
      neuter => grandes
      _ => grandes
    }
  }
  _ => normais
}

form SizeWord(Size) {
  small => pequeno
  big => grande
}

form GenderPronoun(Gender) {
  male => ele
  female => ela
  neuter => ele
  _ => ele
}

form GenderWord(Gender) {
  male => masculino
  female => feminino
  neuter => neutro
  _ => neutro
}

form Delivered(Plural, Gender) {
  one => Entregue
  _ => Entregues
}

nav_why = Porquê
nav_language = Idioma
nav_codegen = Codegen
nav_web = Web
locale_label = Idioma
hero_eyebrow = Localização tipada para equipas de produto
hero_title = Linguini
hero_tagline = Internacionalização para todos nós
hero_copy = Uma linguagem de localização compilada em que esquemas, gramática, formatação CLDR e integração web saem de uma única fonte.
hero_term = /lɪŋˈɡwiːni/
hero_term_kind = NOME
hero_term_hint = tiras longas e estreitas de massa
hero_intro = Linguini transforma ficheiros de localização tipados em código que qualquer app pode usar. Mensagens, gramática, formatadores, fallback de locales e rotas web são verificados no build.
hero_trait_typed = Tipado
hero_trait_compiled = Compilado
hero_trait_native = Nativo
primary_cta = Ler a documentação
secondary_cta = Ver no GitHub
codegen_kicker = Geração de código
codegen_title = Um esquema, saída tipada para cada runtime
codegen_intro = O Linguini analisa contratos .lgs e lógica .lgl uma vez e emite módulos com formatadores CLDR e adaptadores de framework no build.
codegen_ts_title = TypeScript / ESM
codegen_ts_desc = Funções de mensagem tipadas, runtime partilhado e declarações TypeScript.
codegen_svelte_title = Svelte 5 + SvelteKit
codegen_svelte_desc = Rune l gerado, troca de locale e exports handle / reroute / load.
codegen_planned_title = Alvos planeados
codegen_planned_intro = O roadmap é amplo de propósito: Linguini pretende cobrir todos os runtimes, linguagens e frameworks web práticos.
codegen_rust = Rust
codegen_kotlin = Kotlin
codegen_swift = Swift
codegen_go = Go
codegen_python = Python
codegen_csharp = C#
codegen_status_shipped = Disponível
codegen_status_planned = Planeado
web_kicker = SvelteKit
web_title = SvelteKit localizado sem ligação i18n manual
web_intro = Write normal SvelteKit routes and generated message calls. Linguini keeps the active locale, updates messages reactively, and turns invalid message arguments into TypeScript errors.
web_routing = Use ordinary internal links; the generated reroute hook handles localized URLs.
web_cookie = Locale changes persist through cookies and browser storage without app-level state.
web_fallback = Os dados da locale base são incorporados nos módulos gerados durante o build.
web_reactivity = The l rune updates UI text immediately after setLocale.
web_links = Alguns links podem manter a URL original quando não devem ser localizados.
playground_kicker = Playground ao vivo
playground_title = Altere count, fruit, size, gender, amount, date ou locale.
count_label = Quantidade
fruit_label = Fruta
fruit_apple_label = maçã
fruit_pear_label = pera
fruit_orange_label = laranja
