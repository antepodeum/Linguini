playground_sentence = {Delivered(count, gender)} {count} {SizeAdj(size, count, fruit.Gender)} {fruit.nom(count)} para {GenderPronoun(gender)}. Total {amount @currency(code = "EUR")}; data {date}.
cart_summary = O carrinho tem {count} {fruit.nom(count)}
number_format = Formato numérico: {value}
currency_format = Formato de moeda: {amount @currency(code = "EUR")}
date_format = Formato de data: {date}
override_format = Locale override: {amount @number} / {date @date(style = "long")}
gender_line = Forma de género: {GenderWord(gender)}
size_line = Forma de tamanho: {SizeWord(size)}
