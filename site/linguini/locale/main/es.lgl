playground_sentence = {Delivered(count, fruit.Gender)} {count} {SizeAdj(size, count, fruit.Gender)} {fruit.nom(count)} para {GenderPronoun(gender)}. Total {amount @currency(code = "EUR")}; fecha {date}.
cart_summary = El carrito tiene {count} {fruit.nom(count)}
number_format = Formato numérico: {value}
currency_format = Formato moneda: {amount @currency(code = "EUR")}
date_format = Formato fecha: {date}
override_format = Locale override: {amount @number} / {date @date(style = "long")}
gender_line = Forma de género: {GenderWord(gender)}
size_line = Forma de tamaño: {SizeWord(size)}
