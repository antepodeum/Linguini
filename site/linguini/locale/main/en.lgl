impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => apple
      _ => apples
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => pear
      _ => pears
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => orange
      _ => oranges
    }
  }
}

form SizeWord(Size) {
  small => compact
  big => full-size
}

form GenderPronoun(Gender) {
  male => him
  female => her
  neuter => it
  _ => them
}

form GenderWord(Gender) {
  male => masculine
  female => feminine
  neuter => neuter
  _ => neutral
}

form Delivered(Plural, Gender) {
  one {
    male => Delivered
    female => Delivered
    neuter => Delivered
    _ => Delivered
  }
  _ => Delivered
}

nav_why = Why
nav_language = Language
nav_codegen = Codegen
nav_web = Web
locale_label = Locale
hero_eyebrow = Typed localization for product teams
hero_title = Linguini
hero_tagline = Internationalization for the rest of us
hero_copy = A compiled localization language where schemas, locale grammar, CLDR formatting, SvelteKit hooks, cookies, and localized routes are generated from one source.
hero_term = /lɪŋˈɡwiːni/
hero_term_kind = NOUN
hero_term_hint = a pasta of long, flat strands
hero_intro = Linguini is a pasta made from long, flat strands. This language treats localization the same way: messages, grammar, plurals, currency, dates, cookies, and routes stay separate enough to read, then come together as one typed source.
hero_trait_typed = Typed
hero_trait_compiled = Compiled
hero_trait_native = Native
primary_cta = Read the docs
secondary_cta = View GitHub
codegen_kicker = Code generation
codegen_title = One schema, typed output for every runtime
codegen_intro = Linguini analyzes .lgs contracts and .lgl locale logic once, then emits target-specific modules with CLDR formatters, plural selectors, and framework adapters baked in at build time.
codegen_ts_title = TypeScript / ESM
codegen_ts_desc = Typed message functions, shared runtime, declaration files, and optional per-locale tree shaking.
codegen_svelte_title = Svelte 5 + SvelteKit
codegen_svelte_desc = Generated l rune, locale switching, localized href helpers, and handle / reroute / load exports.
codegen_planned_title = Planned targets
codegen_planned_intro = The roadmap is intentionally broad: Linguini is planned to reach every practical runtime, language, and web framework.
codegen_rust = Rust
codegen_kotlin = Kotlin
codegen_swift = Swift
codegen_go = Go
codegen_python = Python
codegen_csharp = C#
codegen_status_shipped = Shipped
codegen_status_planned = Planned
web_kicker = SvelteKit
web_title = Web integration
web_intro = Generated hooks connect your app to locale detection, routing, cookies, and reactive message access without hand-written glue code.
web_routing = Localized paths (/pt-BR/...) via reroute; optional prefix for the default locale.
web_cookie = Cookie and localStorage keep the chosen locale across visits and tabs.
web_fallback = Regional tags inherit missing copy from parent locales (pt-BR → pt → en).
web_reactivity = The l rune updates when the locale changes; anchor hrefs localize on the client.
web_links = data-linguini-ignore opts a link out of automatic localization.
playground_kicker = Live playground
playground_title = Change count, fruit, size, gender, amount, date, or locale.
count_label = Count
fruit_label = Fruit
size_label = Size
gender_label = Gender
amount_label = Amount
