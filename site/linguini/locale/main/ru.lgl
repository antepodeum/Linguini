impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => яблоко
      few => яблока
      _ => яблок
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => груша
      few => груши
      _ => груш
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => апельсин
      few => апельсина
      _ => апельсинов
    }
  }
}

form SizeAdj(Size, Plural, Gender) {
  small {
    one {
      male => маленький
      female => маленькая
      neuter => маленькое
      _ => маленький
    }
    _ => маленьких
  }
  big {
    one {
      male => большой
      female => большая
      neuter => большое
      _ => большой
    }
    _ => больших
  }
  _ => обычные
}

form SizeWord(Size) {
  small => маленький
  big => большой
}

form GenderWord(Gender) {
  male => мужской
  female => женский
  neuter => средний
  _ => нейтральный
}

form GenderPronoun(Gender) {
  male => него
  female => неё
  neuter => него
  _ => него
}

form Delivered(Plural, Gender) {
  one {
    male => Доставлен
    female => Доставлена
    neuter => Доставлено
    _ => Доставлено
  }
  _ => Доставлены
}

nav_why = Зачем
nav_language = Язык
nav_codegen = Кодген
nav_web = Web
locale_label = Локаль
hero_eyebrow = Типизированная локализация для продуктовых команд
hero_title = Linguini
hero_tagline = Интернационализация для всех нас
hero_copy = Компилируемый язык локализации, где схемы, грамматика локали, CLDR-форматирование, SvelteKit hooks, cookie и локализованные маршруты генерируются из одного источника.
hero_term = /lɪŋˈɡwiːni/
hero_term_kind = СУЩ.
hero_term_hint = типизированный компилятор локализации
hero_intro = Linguini превращает типизированные файлы локализации в код, который можно подключить к любому приложению. Сообщения, грамматика, форматтеры, fallback локалей и web-маршруты проверяются на этапе сборки.
hero_trait_typed = Типизированный
hero_trait_compiled = Компилируемый
hero_trait_native = Нативный
primary_cta = Документация
secondary_cta = GitHub
codegen_kicker = Генерация кода
codegen_title = Одна схема — типизированный вывод для каждого рантайма
codegen_intro = Linguini один раз анализирует контракты .lgs и логику .lgl, затем генерирует модули под целевой рантайм с CLDR-форматированием, plural-селекторами и адаптерами фреймворков на этапе сборки.
codegen_ts_title = TypeScript / ESM
codegen_ts_desc = Типизированные функции сообщений, общий runtime, declaration files и tree shaking по локалям.
codegen_svelte_title = Svelte 5 + SvelteKit
codegen_svelte_desc = Сгенерированный rune l, переключение локали, localizeHref и экспорты handle / reroute / load.
codegen_planned_title = Запланированные таргеты
codegen_planned_intro = План широкий намеренно: Linguini должен поддерживать все практичные runtime, языки и web-фреймворки.
codegen_rust = Rust
codegen_kotlin = Kotlin
codegen_swift = Swift
codegen_go = Go
codegen_python = Python
codegen_csharp = C#
codegen_status_shipped = Стабильно
codegen_status_planned = В планах
web_kicker = SvelteKit
web_title = Локализованный SvelteKit без ручной i18n-обвязки
web_intro = Пишите обычные SvelteKit routes и вызывайте сгенерированные сообщения. Linguini хранит активную локаль, реактивно обновляет текст и превращает неверные аргументы сообщений в TypeScript ошибки.
web_routing = Используйте обычные internal links; сгенерированный reroute hook обрабатывает локализованные URL.
web_cookie = Смена локали сохраняется через cookies и browser storage без app-level state.
web_fallback = Данные из базовой локали встраиваются в сгенерированные locale-модули на этапе сборки.
web_reactivity = Rune l обновляет текст UI сразу после setLocale.
web_links = Для отдельных ссылок можно оставить исходный URL без локализации.
playground_kicker = Live playground
playground_title = Меняй количество, фрукт, размер, род, сумму, дату или локаль.
