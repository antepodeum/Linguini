enum Gender { male, female, neuter, other }

impl Fruit {
  apple {
    Gender = neuter
    emoji = 🍎

    form nom(Plural) {
      one => яблоко
      few => яблока
      _   => яблок
    }
  }

  pear {
    Gender = female
    emoji = 🍐

    form nom(Plural) {
      one => груша
      few => груши
      _   => груш
    }
  }

  orange {
    Gender = male
    emoji = 🍊

    form nom(Plural) {
      one => апельсин
      few => апельсина
      _   => апельсинов
    }
  }
}

form SizeAdj(Size, Plural, Gender) {
  small {
    one {
      male   => маленький
      female => маленькая
      neuter => маленькое
      _      => маленький
    }
    few {
      female => маленькие
      _      => маленьких
    }
    _ => маленьких
  }

  big {
    one {
      male   => большой
      female => большая
      neuter => большое
      _      => большой
    }
    few {
      female => большие
      _      => больших
    }
    _ => больших
  }

  _ {
    one {
      male   => обычный
      female => обычная
      neuter => обычное
      _      => обычный
    }
    few {
      female => обычные
      _      => обычных
    }
    _ => обычных
  }
}

form SizeWord(Size) {
  small => маленький
  big   => большой
  _     => обычный
}

form Delivered(Plural, Gender) {
  one {
    male   => Доставлен
    female => Доставлена
    neuter => Доставлено
    _      => Доставлено
  }
  _ => Доставлено
}

